title = {Coherent Elastic Neutrino-Nucleus Scattering},
journal = {Journal of Physics: Conference Series},
abstract = {Coherent elastic neutrino-nucleus scattering (CEvNS), the gentlest kind of interaction of a neutrino with an entire nucleus, was first predicted in 1974, but not observed until 2017 by the COHERENT collaboration. COHERENT and many other experiments are pursuing further measurements of this low momentum transfer process. We review the physics motivations for these measurements and prospects and status of current and future CEvNS experiments.}
}
