@article{
science.aao4050,
author = {Jonathan M. Link },
title = {Scattering neutrinos caught in the act},
journal = {Science},
volume = {357},
number = {6356},
pages = {1098-1099},
year = {2017},
doi = {10.1126/science.aao4050},
URL = {https://www.science.org/doi/abs/10.1126/science.aao4050},
eprint = {https://www.science.org/doi/pdf/10.1126/science.aao4050},
abstract = {Neutrino experiment finds new tool to search for physics beyond the standard model Neutrinos are one of the most common particles in the universe, yet they are one of the most difficult to study. That is because neutrinos, which have no electrical charge, interact very weakly. For example, it has been claimed that a typical neutrino from radioactive decay can pass through a light-year–long column of lead with only a fifty-fifty chance of interacting. On page 1123 of this issue, Akimov et al. (1) report results that call this claim into question. Their work describes the observation of a process known as coherent elastic neutrino-nucleus scattering (or CEνNS), which was first predicted by Freedman in 1974 (2).}}

