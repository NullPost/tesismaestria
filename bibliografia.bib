@article{OBERAUER2002301,
title = {Coherent neutrino nucleus scattering},
journal = {Progress in Particle and Nuclear Physics},
volume = {48},
number = {1},
pages = {301-304},
year = {2002},
issn = {0146-6410},
doi = {https://doi.org/10.1016/S0146-6410(02)00137-0},
url = {https://www.sciencedirect.com/science/article/pii/S0146641002001370},
author = {L. Oberauer},
abstract = {The elastic, coherent neutrino scattering off nuclei is discussed. State of the art cryogenic detectors as developed for the search of Dark Matter could be used to measure for the first time the cross section of this process. Event rates for different target materials are calculated for typical neutrino fluxes obtainable at nuclear power plants. The background conditions are estimated and the relevant parameters of the laboratory at the Krasnojarsk reactor station is shortly described. Finally the role of coherent scattering in gravitational collapses is reviewed and the event rates of galactic supernovae neutrinos in future cryogenic detectors with mass scales of about 1 ton is estimated.}
}
